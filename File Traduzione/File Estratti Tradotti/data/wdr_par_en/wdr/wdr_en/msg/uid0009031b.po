msgctxt "6808"
msgid "Setsuko"
msgstr "Setsuko"

msgctxt "6812"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "6816"
msgid "Arima"
msgstr "Arima"

msgctxt "6820"
msgid "Shiobara"
msgstr "Shiobara"

msgctxt "6824"

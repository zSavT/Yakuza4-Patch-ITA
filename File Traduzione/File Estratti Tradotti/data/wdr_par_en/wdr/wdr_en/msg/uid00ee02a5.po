msgctxt "256"
msgid "The barkeep of Cuez Bar is now your ally."
msgstr "Il barista del Cuez Bar è ora tuo alleato."

msgctxt "436"
msgid "After using the coupon, your Kamuro Gourmet magazine was discarded."
msgstr ""
"Dopo aver usato il coupon, la tua rivista Kamuro Gourmet è stata buttata "
"via."

msgctxt "640"
msgid "After using the coupon, your Kamuro Gourmet magazine was discarded."
msgstr ""
"Dopo aver usato il coupon, la tua rivista Kamuro Gourmet è stata buttata "

msgctxt "168"
msgid "Quit"
msgstr "Esci"

msgctxt "173"
msgid "Cancel the order."
msgstr "Annulla l'ordine."

msgctxt "191"
msgid "Order"
msgstr "Ordina"

msgctxt "197"
msgid "Order the currently selected item.  "
msgstr "Ordina l'articolo selezionato."

msgctxt "234"
msgid "(I haven't picked anything.)  "
msgstr "(Non ho scelto nulla.)"

msgctxt "265"
msgid "(I'm short on cash.)  "
msgstr "(Non ho abbastanza soldi.)"

msgctxt "288"
msgid "Thank you. That'll be %s."
msgstr "Grazie. Il totale è di %s."

msgctxt "314"
msgid "(I can't carry any more stuff.)"
msgstr "(Non posso trasportare altri oggetti.)"

msgctxt "346"
msgid "(They're sold out.)"
msgstr "(Sono esauriti.)"

msgctxt "366"
msgid ""
"Delicious tonkotsu ramen topped with a soft-boiled "
"egg."
msgstr ""
"Delizioso ramen tonkotsu guarnito con un uovo alla "
"coque."

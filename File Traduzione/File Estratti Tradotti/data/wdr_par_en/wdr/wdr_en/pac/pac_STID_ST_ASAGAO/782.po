msgctxt "128"
msgid ""
"Go, Dragon Mask! Give him\r\n"
"a Dragon Butt Kicking!"
msgstr "Vai, Dragon Mask! Fagli\r\nil sedere a strisce alla Dragon!"

msgctxt "140"
msgid "<Color:7>Throw<Color:Default> him, Dragon!"
msgstr "<Color:7>Lancialo<Color:Default>, Dragon!"

msgctxt "152"
msgid ""
"Get in there!\r\n"
"You've gotta <Color:7>throw<Color:Default> him!"
msgstr "Vai lì!\r\nDevi <Color:7>lanciarlo<Color:Default>!"

msgctxt "164"
msgid "<Color:7>Toss<Color:Default> that jerk!"
msgstr "<Color:7>Scaraventa via<Color:Default> quel cretino!"

msgctxt "176"
msgid "Dragon! Look out!"
msgstr "Dragon! Attento!"

msgctxt "188"
msgid ""
"Come on, Dragon!\r\n"
"Give him the ol' <Color:7>dropkick<Color:Default>!"
msgstr ""
"Dai, Dragon!\r\n"
"Fagli il caro vecchio <Color:7>dropkick<Color:Default>!"

msgctxt "200"
msgid "Now! Hit him with a <Color:7>dropkick<Color:Default>!"
msgstr "Ora! Colpiscilo con un <Color:7>dropkick<Color:Default>!"

msgctxt "212"
msgid ""
"Sprint towards him,\r\n"
"then do a <Color:7>dropkick<Color:Default>!"
msgstr ""
"Corri verso di lui,\r\n"
"e poi fai un <Color:7>dropkick<Color:Default>!"

msgctxt "224"
msgid "I'm rooting for you, Ricky Mask!"
msgstr "Faccio il tifo per te, Ricky Mask!"

msgctxt "236"
msgid ""
"You better not lose,\r\n"
"Ricky Mask!"
msgstr ""
"Vedi di non perdere,\r\n"
"Ricky Mask!"

msgctxt "248"
msgid ""
"Hey, Ricky!\r\n"
"Hit him harder!"
msgstr ""
"Ehi, Ricky!\r\n"
"Colpiscilo più forte!"

msgctxt "260"
msgid ""
"Go go let's go\r\n"
"Ricky Ricky Mask!"
msgstr ""
"Forza forza vai\r\n"
"Ricky Ricky Mask!"

msgctxt "272"
msgid "You got this, Dragon!"
msgstr "Ce la puoi fare, Dragon!"

msgctxt "284"
msgid ""
"Ricky!\r\n"
"Now's your chance!"
msgstr ""
"Ricky!\r\n"
"È la tua occasione!"

msgctxt "296"
msgid ""
"Don't stop now!\r\n"
"Go in for another <Color:7>dropkick<Color:Default>!"
msgstr ""
"Non fermarti ora!\r\n"
"Vai con un altro <Color:7>dropkick<Color:Default>!"

msgctxt "308"
msgid "Let's go! Do a <Color:7>dropkick<Color:Default>!"
msgstr "Forza! Fai un <Color:7>dropkick<Color:Default>!"

msgctxt "320"
msgid ""
"Chaaaarge!\r\n"
"Give him a <Color:7>dropkick<Color:Default>!"
msgstr ""
"Caaarica!\r\n"
"Fagli un <Color:7>dropkick<Color:Default>!"

msgctxt "332"
msgid ""
"Finish him with\r\n"
"a <Color:7>special move<Color:Default>!"
msgstr ""
"Finiscilo con\r\n"
"una <Color:7>mossa speciale<Color:Default>!"

msgctxt "344"
msgid ""
"He's almost down!\r\n"
"Give him a <Color:7>special move<Color:Default>!"
msgstr ""
"È quasi al tappeto!\r\n"
"Fagli una <Color:7>mossa speciale<Color:Default>!"

msgctxt "356"
msgid ""
"Hey! I wanna see you\r\n"
"do a <Color:7>special move<Color:Default>!"
msgstr ""
"Ehi! Voglio vederti\r\n"
"fare una <Color:7>mossa speciale<Color:Default>!"

msgctxt "368"
msgid "Don't choke, Dragon!"
msgstr "Non cedere, Dragon!"
msgctxt "200"
msgid "You're amazing, Uncle Kaz!"
msgstr "Sei incredibile, zio Kaz!"

msgctxt "212"
msgid "You're like a real baseball player!"
msgstr "Sembri un vero giocatore di baseball!"

msgctxt "248"
msgid "Oh, you were so close!"
msgstr "Oh, c'eri quasi!"

msgctxt "260"
msgid "Let's try again!"
msgstr "Riproviamo!"

msgctxt "272"
msgid "I wanted to see you get a home run..."
msgstr "Volevo vederti battere un fuoricampo..."

msgctxt "320"
msgid "Uncle Kaz!"
msgstr "Zio Kaz!"

msgctxt "332"
msgid "The Hard Game is open."
msgstr "La modalità Difficile è aperta."

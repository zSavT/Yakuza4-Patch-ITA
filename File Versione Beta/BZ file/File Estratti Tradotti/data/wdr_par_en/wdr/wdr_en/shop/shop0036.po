msgctxt "196"
msgid "Quit"
msgstr "Esci"

msgctxt "201"
msgid "Cancel the order."
msgstr "Annulla l'ordine."

msgctxt "219"
msgid "Order"
msgstr "Ordina"

msgctxt "225"
msgid "Order the currently selected item.  "
msgstr "Ordina l'oggetto selezionato."

msgctxt "262"
msgid "(I haven't picked anything.)  "
msgstr "(Non ho scelto niente.)"

msgctxt "293"
msgid "(I'm short on cash.)  "
msgstr "(Non ho abbastanza soldi.)"

msgctxt "316"
msgid "Thank you. That'll be %s."
msgstr "Grazie. Fanno %s."

msgctxt "342"
msgid "(I can't carry any more stuff.)"
msgstr "(Non posso trasportare altri oggetti.)"

msgctxt "374"
msgid "(They're sold out.)"
msgstr "(È esaurito.)"

msgctxt "394"
msgid ""
"A body-hugging, halter-neck dress that amplifies its "
"wearer's sexiness."
msgstr ""
"Un abito aderente con allacciatura al collo che amplifica "
"la sensualità di chi lo indossa."

msgctxt "466"
msgid ""
"The elegant body line and sophisticated color of this "
"dress are sure to turn heads."
msgstr ""
"La linea elegante e il colore sofisticato di questo "
"vestito faranno sicuramente girare la testa."

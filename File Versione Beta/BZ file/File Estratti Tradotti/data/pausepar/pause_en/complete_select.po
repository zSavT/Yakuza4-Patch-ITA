msgctxt "414\tEXPLANATION"
msgid "Unlock all 100 lockers, both above and underground."
msgstr "Sblocca tutti i 100 armadietti, sia in superficie che nei sotterranei."

msgctxt "466\tEXPLANATION"
msgid "Order everything on the menu at every restaurant."
msgstr "Ordina tutto dal menu di ogni ristorante."

msgctxt "516\tEXPLANATION"
msgid "Make all weapons and gear for both Kamiyama Works shops."
msgstr ""
"Crea tutte le armi e gli equipaggiamenti per entrambi i negozi Kamiyama Works."

msgctxt "573\tEXPLANATION"
msgid "Befriend everyone you can in the city."
msgstr "Fai amicizia con tutti in città."

msgctxt "612\tEXPLANATION"
msgid "See all Revelations."
msgstr "Assisti a tutte le Rivelazioni."

msgctxt "633\tEXPLANATION"
msgid ""
"Complete every minigame. Each minigame's completion status can\n"
"be viewed with <Action:Button_Cross@UI>."
msgstr ""
"Completa tutti i minigiochi. Lo stato di completamento di ogni minigioco\n"
"può essere visualizzato con <Action:Button_Cross@UI>."

msgctxt "737\tEXPLANATION"
msgid "Complete all hostess substories."
msgstr "Completare tutte le sottostorie delle hostess."

msgctxt "770\tEXPLANATION"
msgid "Complete all Hostess Maker hostess substories."
msgstr "Completa tutte le sottostorie di hostess di Hostess Maker."

msgctxt "817\tEXPLANATION"
msgid "Train all Hostess Maker hostesses to be number one."
msgstr "Addestra tutte le hostess del Hostess Maker ad essere la numero uno."

msgctxt "869\tEXPLANATION"
msgid "Clear all of Saigo's training courses."
msgstr "Completare tutti i corsi di addestramento di Saigo."

msgctxt "908\tEXPLANATION"
msgid "Complete all of Master's tasks."
msgstr "Completa tutti i compiti del Maestro."

msgctxt "940\tEXPLANATION"
msgid "Help Nair reach her objective."
msgstr "Aiuta Nair a raggiungere il suo obiettivo."

msgctxt "971\tEXPLANATION"
msgid "Win all tournaments at the Coliseum."
msgstr "Vinci tutti i tornei al Colosseo."

msgctxt "1008\tEXPLANATION"
msgid "All your apprentices must win the Rookie Tournament."
msgstr "Tutti i tuoi apprendisti devono vincere il Torneo dei Principianti."

msgctxt "1061\tEXPLANATION"
msgid "Resolve specific cases heard on the police scanner."
msgstr "Risolvi casi specifici sentiti dallo scanner della polizia."

msgctxt "1113\tEXPLANATION"
msgid "Defeat all gangs."
msgstr "Sconfiggi tutte le bande."

msgctxt "1131\tEXPLANATION"
msgid "Defeat all enemies."
msgstr "Sconfiggi tutti i nemici."

msgctxt "1151\tEXPLANATION"
msgid "Use every Furore Action."
msgstr "Usa ogni Azione Calore."

msgid "Body Slam  "
msgstr "Schianto Corporeo"

msgctxt "156\tKIND"
msgid "German Suplex  "
msgstr "Suplex tedesco"

msgctxt "172\tKIND"
msgid "Bear Hug  "
msgstr "Presa dell'Orso"

msgctxt "183\tKIND"
msgid "Essence of Opportune Strikes"
msgstr "Essenza dei Colpi Opportuni"

msgctxt "212\tKIND"
msgid "Essence of Fence Bashing"
msgstr "Essenza dello schianto contro la rete"

msgctxt "237\tKIND"
msgid "Essence of Fence Smashing"
msgstr "Essenza del massacro contro la rete"

msgctxt "263\tKIND"
msgid "Guard Breaker  "
msgstr "Rompiguardia"

msgctxt "279\tKIND"
msgid "Wall Bounce Combo  "
msgstr "Combo con rimbalzo a parete"

msgctxt "299\tKIND"
msgid "Special Skill 08"
msgstr "Abilità Speciale 08"

msgctxt "316\tKIND"
msgid "Special Skill 09  "
msgstr "Abilità Speciale 09"

msgctxt "335\tMSG"
msgid ""
"A simple yet powerful body slam.\n"
"Power: Low"
msgstr ""
"Un body slam semplice ma potente.\n"
"Potenza: Bassa"

msgctxt "379\tMSG"
msgid ""
"Move quickly to the rear of the opponent to perform a suplex move.\n"
"Power: Low"
msgstr ""
"Muoviti rapidamente alle spalle dell'avversario per eseguire un suplex.\n"
"Potenza: Bassa"

msgctxt "457\tMSG"
msgid ""
"Uses brute strength to toss the opponent far away.\n"
"Power: Medium"
msgstr ""
"Usa la forza bruta per scaraventare l'avversario lontano.\n"
"Potenza: Media"

msgctxt "522\tMSG"
msgid ""
"A powerful standing attack using knee and leg kick combos.\n"
"Power: Medium"
msgstr ""
"Un potente attacco in piedi che sfrutta combo di ginocchiate e calci alle gambe.\n"
"Potenza: Media"

msgctxt "595\tMSG"
msgid ""
"Stomp an enemy with brute leg strength.\n"
"Power: High"
msgstr ""
"Calpesta un nemico con la forza bruta delle gambe.\n"
"Potenza: Alta"

msgctxt "647\tMSG"
msgid ""
"Punch the face of a downed enemy without mercy.\n"
"Power: High ~Can only be used when opponent is down."
msgstr ""
"Colpisci il viso di un nemico a terra senza pietà.\n"
"Potenza: Alta ~Utilizzabile solo quando l'avversario è a terra."

msgctxt "748\tMSG"
msgid ""
"Launch a downed enemy into the air for a clothesline.\n"
"Power: Super ~Can only be used when opponent is down."
msgstr ""
"Lancia in aria un nemico a terra per colpirlo con una clothesline.\n"
"Potenza: Super ~Utilizzabile solo quando l'avversario è a terra."

msgctxt "856\tMSG"
msgid ""
"A merciless attack that slams an enemy's face into a fence.\n"
"Power: Medium ~Can only be used when grabbing an opponent."
msgstr ""
"Un attacco spietato che sbatte la faccia di un nemico contro una recinzione.\n"
"Potenza: Media\n"
"~Utilizzabile solo quando si afferra un avversario."

msgctxt "975\tMSG"
msgid ""
"Grab and power slam an enemy into the ground.\n"
"Power: Super ~Can only be used while grabbing an opponent."
msgstr ""
"Afferrare e schiantare con forza un nemico a terra.\n"
"Potenza: Super ~Può essere usato solo mentre si afferra un avversario."

msgctxt "1080\tMSG"
msgid ""
"An extremely powerful move that knocks the enemy face down by leveraging your entire body strength.\n"
"Power: High"
msgstr ""
"Una mossa estremamente potente che atterra il nemico a faccia in giù sfruttando tutto il peso del tuo corpo.\n"
"Potenza: Alta"
